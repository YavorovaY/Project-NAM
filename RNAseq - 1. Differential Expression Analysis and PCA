### 1. The Count Matrix Was Created ###

files <- list.files(pattern = "_ct_genes\\.txt$", full.names = TRUE)

lst <- lapply(files, function(f) {
  dt <- fread(f, col.names = c("gene", basename(f)))  
})

merged <- Reduce(function(x, y) merge(x, y, by = "gene", all = TRUE), lst)

merged[is.na(merged)] <- 0

gene_ids <- merged$gene
count_mat <- as.matrix(merged[, -1])
rownames(count_mat) <- gene_ids
colnames(count_mat) <- sub("_ct_genes\\.txt$", "", basename(files))
dim(count_mat)
head(count_mat[, 1:3])

fwrite(merged, "nam_counts_matrix.tsv")





### 2. DDS Object Preparation ###

Counts <- count_mat                               
storage.mode(Counts) <- "integer"                 
Counts <- Counts[rowSums(Counts) > 100, , drop=FALSE]  


samples <- colnames(Counts)

Training <- ifelse(grepl("^Naive",   samples), "Naive",
                   ifelse(grepl("^Trained", samples), "Trained", NA))

CellType <- ifelse(grepl("NAM", samples, ignore.case=TRUE), "NAM",
                   ifelse(grepl("AM",  samples, ignore.case=TRUE), "AM", NA))

stopifnot(!any(is.na(Training)), !any(is.na(CellType)))

condition <- factor(paste(Training, CellType, sep="_"),
                    levels = c("Naive_NAM","Naive_AM","Trained_NAM","Trained_AM"))

print(table(condition))

coldata <- data.frame(row.names = samples, condition = condition)

dds <- DESeqDataSetFromMatrix(countData = Counts,
                              colData   = coldata,
                              design    = ~ condition)

dds <- DESeq(dds)   # will estimate size factors & dispersions itself





### 3. PCA Plot ###


if (!exists("vsd")) {
  vsd <- vst(dds, blind = TRUE)
}

cd <- as.data.frame(colData(vsd))
cd$sample <- rownames(cd)

if (!"condition" %in% names(cd) && all(c("Training", "CellType") %in% names(cd))) {
  cd$condition <- factor(paste(cd$Training, cd$CellType, sep = "_"))
}


rep_guess <- sub(".*[-_](\\d+).*", "\\1", cd$sample)
rep_guess[rep_guess == cd$sample] <- NA  # if the regex didn't find a number


if (anyNA(rep_guess)) {
  rep_guess <- ave(cd$sample, cd$condition, FUN = function(v) seq_along(v))
}

cd$replicate <- as.character(rep_guess)

colData(vsd) <- DataFrame(cd)

pca_data <- plotPCA(vsd, intgroup = c("condition","replicate"), returnData = TRUE)
percentVar <- round(100 * attr(pca_data, "percentVar"))


shape_map <- c("1" = 21, "2" = 22, "3" = 23, "4" = 24, "5" = 25)
pca_data$rep_num <- as.character(pca_data$replicate)
if (!all(pca_data$rep_num %in% names(shape_map))) {
  # extend shapes if you have >5 replicates
  extra_levels <- setdiff(unique(pca_data$rep_num), names(shape_map))
  extra_shapes <- setdiff(21:25, shape_map)  # reuse pool if needed
  shape_map <- c(shape_map, setNames(rep(21, length(extra_levels)), extra_levels))
}

PCA_plot <- ggplot(pca_data, aes(PC1, PC2, fill = condition, shape = rep_num)) +
  geom_point(size = 5, color = "black", stroke = 0.5) +
  scale_shape_manual(values = shape_map) +
  scale_fill_brewer(palette = "Set2") +
  labs(
    title = "PCA — all conditions",
    x = paste0("PC1: ", percentVar[1], "% variance"),
    y = paste0("PC2: ", percentVar[2], "% variance")
  ) +
  theme_minimal(base_size = 14) +
  guides(
    fill  = guide_legend(override.aes = list(shape = 21, color = "black"), title = "Condition"),
    shape = guide_legend(title = "Replicate")
  )

PCA_plot.





### 4. Differential Expression Analysis ###

NAM_Trained_vs_Naive = results(dds, contrast = c("condition", "Trained_NAM", "Naive_NAM"))

NAM_Trained_vs_Naive_clean = na.omit(NAM_Trained_vs_Naive)

NAM_Trained_vs_Naive_clean_sig = NAM_Trained_vs_Naive_clean[NAM_Trained_vs_Naive_clean$padj < 0.05,]

NAM_Trained_vs_Naive_clean_sig_upreg <- NAM_Trained_vs_Naive_clean_sig[NAM_Trained_vs_Naive_clean_sig$log2FoldChange > 0, ]

NAM_Trained_vs_Naive_clean_sig_downreg <- NAM_Trained_vs_Naive_clean_sig[NAM_Trained_vs_Naive_clean_sig$log2FoldChange < 0, ]

write.csv(NAM_Trained_vs_Naive_clean, file = "NAM_Trained_vs_Naive All DEGs.csv")



